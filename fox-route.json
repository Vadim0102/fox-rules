{
    "name": "fox",
    "proxy": -2,
    "rules": [
        {
            "action": "hijack-dns",
            "protocol": "dns"
        },
        {
            "action": "reject",
            "rule_set": [
                "geosite-category-ads-all"
            ]
        },
        {
            "action": "route",
            "outbound": "direct",
            "process_name": [
                "sing-box.exe",
                "nekobox_core.exe",
                "nekobox.exe",
                "winws.exe"
            ]
        },
        {
            "action": "route",
            "outbound": "direct",
            "ip_is_private": true
        },
        {
            "action": "route",
            "outbound": "direct",
            "domain_suffix": [
                ".local",
                ".localhost",
                ".lan"
            ]
        },
        {
            "action": "route",
            "outbound": "direct",
            "rule_set": [
                "geosite-youtube",
                "geosite-discord"
            ]
        },
        {
            "action": "route",
            "outbound": "proxy",
            "rule_set": [
                "geoip-ru-blocked",
                "geoip-ru-blocked-community",
                "geosite-ru-blocked",
                "geosite-roblox"
            ]
        },
        {
            "action": "route",
            "outbound": "direct",
            "rule_set": [
                "geosite-ru-available-only-inside",
                "geosite-ru",
                "geosite-category-ru",
                "geoip-ru",
                "geosite-category-games"
            ]
        },
        {
            "action": "route",
            "outbound": "proxy"
        }
    ],
    "skip_update": false,
    "url": "https://cdn.jsdelivr.net/gh/Vadim0102/fox-rules@main/fox-route.json"
}
